# ============================================================
# HALO — Lone Worker Safety Alert Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# ============================================================

# ---------- Email Alerts (Gmail recommended) ----------
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Paste it below (16 chars, no spaces)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
ALERT_RECIPIENT_EMAILS=recipient1@gmail.com,recipient2@gmail.com

# ---------- Telegram Alerts (optional) ----------
# Create a bot via @BotFather on Telegram, get the token
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Twilio SMS Alerts (optional) ----------
# Sign up at twilio.com, get Account SID and Auth Token
# Get a Twilio phone number and set recipient
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_RECIPIENT_PHONE=

# ---------- Dashboard ----------
# Password to access the Streamlit dashboard
DASHBOARD_PASSWORD=admin

# ---------- Camera ----------
CAMERA_INDEX=0

# ---------- Geofencing ----------
# Define a restrictive polygon zone as x,y coordinates separated by semicolons
# Example: 100,100;400,100;400,400;100,400
RESTRICTED_ZONE_POLYGON=

# ---------- Detection Thresholds ----------
PERSON_CONF=0.4
FALL_PERSIST_S=3.0
IDLE_THRESHOLD_S=600
NORMAL_SNAPSHOT_EVERY_S=30

# ---------- Tracking ----------
TRACK_MATCH_DIST_PX=140
IDLE_MOVE_THRESH_PX=50
TRACK_FORGET_S=5

# ---------- Sound Alerts ----------
ENABLE_SOUND_ALERT=true
